  text: {fileID: 2350999942706920749}
  image: {fileID: 6678072362742689311}
  tutorialInfos:
  - text: "\uBC29\uD5A5\uD0A4\uB85C \uC6C0\uC9C1\uC5EC\uBCF4\uC138\uC694."
    sprite: {fileID: 21300000, guid: 7ab74e659e1f0a34d9cfec21c478fc12, type: 3}
  - text: "\uAC00\uB9CC\uD788 \uC788\uC73C\uBA74 \uC544\uB798\uB85C \uB5A8\uC5B4\uC9D1\uB2C8\uB2E4."
    sprite: {fileID: 21300002, guid: 7ab74e659e1f0a34d9cfec21c478fc12, type: 3}
  - text: "\uC2A4\uD398\uC774\uC2A4\uBC14\uB97C \uB20C\uB7EC \uC0C1\uC2B9\uD558\uC138\uC694."
    sprite: {fileID: 21300010, guid: 7ab74e659e1f0a34d9cfec21c478fc12, type: 3}
  - text: "\uB3D9\uB8CC\uB97C \uB9CC\uB098\uBA74 \uBAA9\uC228\uC774 \uCD94\uAC00\uB429\uB2C8\uB2E4.
      \uB3D9\uB8CC\uAC00 \uB9CE\uC744\uC218\uB85D \uC18D\uB3C4\uAC00 \uBE68\uB77C\uC9D1\uB2C8\uB2E4."
    sprite: {fileID: 21300004, guid: 7ab74e659e1f0a34d9cfec21c478fc12, type: 3}
  - text: "\uBB3C\uC18D\uC758 \uC9F1\uB6B1\uC5B4\uB97C \uC870\uC2EC\uD558\uC138\uC694!
      \uBB3C \uBC16\uC73C\uB85C \uACF5\uACA9\uD569\uB2C8\uB2E4."
    sprite: {fileID: 21300006, guid: 7ab74e659e1f0a34d9cfec21c478fc12, type: 3}
  - text: "\uB3C5\uC218\uB9AC\uB294 \uBC14\uB77C\uBCF4\uB294 \uBC29\uD5A5\uC73C\uB85C
      \uC77C\uC9C1\uC120 \uACF5\uACA9\uC744 \uD569\uB2C8\uB2E4"
    sprite: {fileID: 21300008, guid: 7ab74e659e1f0a34d9cfec21c478fc12, type: 3}
